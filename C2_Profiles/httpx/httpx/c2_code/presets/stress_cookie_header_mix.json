{
  "name": "Stress Cookie Header Mix",
  "get": {
    "verb": "GET",
    "uris": [
      "/msdownload/update/v1/check",
      "/msdownload/update/v1/scan"
    ],
    "client": {
      "headers": {
        "Accept": "*/*",
        "Accept-Encoding": "identity",
        "Connection": "Keep-Alive",
        "Pragma": "no-cache",
        "User-Agent": "Microsoft BITS/7.8"
      },
      "parameters": {
        "channel": "stable ring",
        "osver": "10.0/26100",
        "source": "cookie-flow"
      },
      "message": {
        "location": "cookie",
        "name": "WU-SESSION"
      },
      "transforms": [
        {
          "action": "prepend",
          "value": "sid-"
        },
        {
          "action": "base64url",
          "value": ""
        }
      ]
    },
    "server": {
      "headers": {
        "Cache-Control": "private, max-age=0",
        "Content-Type": "text/plain; charset=utf-8",
        "Server": "Microsoft-HTTPAPI/2.0"
      },
      "transforms": [
        {
          "action": "base64url",
          "value": ""
        },
        {
          "action": "append",
          "value": ".ok"
        }
      ]
    }
  },
  "post": {
    "verb": "POST",
    "uris": [
      "/msdownload/update/v1/report",
      "/msdownload/update/v1/events"
    ],
    "client": {
      "headers": {
        "Accept": "*/*",
        "Connection": "Keep-Alive",
        "Content-Type": "application/json; charset=utf-8",
        "Pragma": "no-cache",
        "User-Agent": "Microsoft BITS/7.8",
        "X-Client": "header-flow"
      },
      "parameters": {
        "attempt": "1",
        "mode": "header"
      },
      "message": {
        "location": "header",
        "name": "X-Ms-Trace"
      },
      "transforms": [
        {
          "action": "xor",
          "value": "HdrKey42"
        },
        {
          "action": "netbiosu",
          "value": ""
        }
      ]
    },
    "server": {
      "headers": {
        "Cache-Control": "no-cache",
        "Content-Type": "application/json; charset=utf-8",
        "Server": "Microsoft-HTTPAPI/2.0"
      },
      "transforms": [
        {
          "action": "prepend",
          "value": "{\"token\":\""
        },
        {
          "action": "base64url",
          "value": ""
        }
      ]
    }
  }
}
